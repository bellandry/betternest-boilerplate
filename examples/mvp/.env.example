# ─────────────────────────────────────────────────────────────
# Root shared env. Copy to .env for docker-compose + local dev.
# App-specific env lives in apps/web/.env and apps/api/.env
# ─────────────────────────────────────────────────────────────

# Postgres (consumed by docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=my_app

# Prisma connection string (used by packages/db + apps/api)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/my_app?schema=public
