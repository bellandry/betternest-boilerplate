# ── Single source of truth — copy this to .env ───────────────────────
# Every package reads this file. No apps/api/.env, no apps/web/.env.

# ── Database ──
# --- Database (Prisma -> PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/my_app?schema=public

# ── Auth ──
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# The public origin the browser uses = the Next.js app
WEB_URL=http://localhost:3000

# API port (Next.js proxy forwards here via API_URL)
PORT=4000

# ── Rate Limiting ──
# Max attempts per endpoint per sliding window (15 minutes by default).
RATE_LIMIT_MAX=5
# Window in seconds (900 = 15 minutes).
RATE_LIMIT_WINDOW=900
# Optional: Redis URL for distributed rate limiting (multi-instance deploys).
# Requires: npm install @nest-lab/throttler-storage-redis ioredis
# REDIS_URL=

# ── Email (set via the email-password auth provider) ──
# --- Email (required for email verification & password reset) ---
# Which driver @repo/email uses: "resend" (default) or "smtp".
EMAIL_PROVIDER=resend
# A verified sender address. This MUST be set — there is no default fallback.
# Resend:   a verified domain, e.g. noreply@yourdomain.com
# SMTP:     your SMTP user address, e.g. your.email@gmail.com
EMAIL_FROM=

# EMAIL_PROVIDER=resend — create a key at https://resend.com/api-keys
RESEND_API_KEY=

# EMAIL_PROVIDER=smtp — any SMTP server (Gmail, Postmark, SES, Mailpit, ...)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Optional. Defaults to true for port 465, false otherwise.
SMTP_SECURE=

# --- Google OAuth (see README "OAuth setup") ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth (see README "OAuth setup") ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Docker Compose (for PostgreSQL / MySQL) ──
# # PostgreSQL
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=my_app
#
# # MySQL
# MYSQL_ROOT_PASSWORD=mysql
# MYSQL_DATABASE=my_app
