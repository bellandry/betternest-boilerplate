# apps/web environment
# Internal URL of the NestJS API. Used by:
#  - next.config.ts rewrites (browser-facing same-origin proxy)
#  - lib/auth-server.ts (server-to-server session fetch)
# The browser NEVER sees this value.
API_URL=http://localhost:4000

# Public URL of this Next.js app (used for absolute links / metadata if needed)
NEXT_PUBLIC_APP_URL=http://localhost:3000
