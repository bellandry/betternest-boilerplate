# ─────────────────────────────────────────────────────────────
# Root shared env. Copy to .env.
# App-specific env lives in apps/web/.env and apps/api/.env
# ─────────────────────────────────────────────────────────────

# ── Docker Compose (only for server databases) ──
# Uncomment and configure the section that matches your Docker service.
# See docker-compose.yml for the corresponding service definition.

# PostgreSQL
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=test_app

# MySQL
# MYSQL_ROOT_PASSWORD=mysql
# MYSQL_DATABASE=test_app
