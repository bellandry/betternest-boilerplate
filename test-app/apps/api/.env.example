# apps/api environment

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# The public origin the browser uses = the Next.js app.
# Used for trustedOrigins + baseURL (OAuth callbacks are built from this).
WEB_URL=http://localhost:3000

# API port (Next.js proxy forwards here via API_URL)
PORT=4000

# --- Database (Drizzle -> PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/test_app

# --- Email (required for email verification & password reset) ---
# Which driver @repo/email uses: "resend" (default) or "smtp".
EMAIL_PROVIDER=resend
# A verified sender address. This MUST be set — there is no default fallback.
# Resend:   a verified domain, e.g. noreply@yourdomain.com
# SMTP:     your SMTP user address, e.g. your.email@gmail.com
EMAIL_FROM=

# EMAIL_PROVIDER=resend — create a key at https://resend.com/api-keys
RESEND_API_KEY=

# EMAIL_PROVIDER=smtp — any SMTP server (Gmail, Postmark, SES, Mailpit, ...)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Optional. Defaults to true for port 465, false otherwise.
SMTP_SECURE=

# --- Google OAuth (see README "OAuth setup") ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth (see README "OAuth setup") ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
