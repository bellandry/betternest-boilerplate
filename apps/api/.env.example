# apps/api environment
# Postgres connection (matches root docker-compose.yml default creds)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goldenpath?schema=public

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# The public origin the browser uses = the Next.js app.
# Used for trustedOrigins + baseURL (OAuth callbacks are built from this).
WEB_URL=http://localhost:3000

# OAuth credentials — see README "OAuth setup".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# API port (Next.js proxy forwards here via API_URL)
PORT=4000
